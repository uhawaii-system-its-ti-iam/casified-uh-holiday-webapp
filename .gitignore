# local env files
app/src/.env*.local

# vercel
app/src/.vercel

# typescript
next-env.d.ts

# Ignore build artifacts
tsconfig.tsbuildinfo

# IDEs
.idea
.vscode
app/src/.idea
app/src/.vscode

# package-lock
package-lock.json

# api
api/.classpath
api/.project
api/.settings
api/bin
api/target
api/*-overrides.properties
api/output.txt
api/src/main/resources/static/javascript/tsconfig.json
api/*.iml
