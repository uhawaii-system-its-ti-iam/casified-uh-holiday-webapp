# dependencies
**/node_modules
app/src/.pnp
app/src/pnp.js

# testing
app/src/coverage

# next.js
.next/
app/src/out/

# production
app/src/build

# misc
**/.DS_Store
app/*.pem

# debug
app/src/npm-debug.log*
app/src/yarn-debug.log*
app/src/yarn-error.log*
